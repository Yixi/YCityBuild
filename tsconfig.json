{
  "compilerOptions": {
    "paths": {
      "@root/*": ["./src/*"]
    },
    "rootDir": "./src",
    "outDir": "./dist/",
    "sourceMap": true,
    "strict": false,
    "noImplicitAny": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": [
      "ES2020",
      "DOM"
    ],
    "target": "ES2020",
    "allowJs": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true
  },
  "include": [
    "./src"
  ]
}
